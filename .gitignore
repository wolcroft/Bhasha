# Model export
model-export/bhasha-models/
model-export/models/
model-export/models-merged/
model-export/onnx/
model-export/onnx-quantized/
model-export/venv/
model-export/raw/
model-export/data/
# Keep lora-adapters final weights but skip in-progress checkpoints and
# tokenizer duplicates (dict.*.json, model.SRC/TGT are copies of en-indic base).
model-export/lora-adapters/**/checkpoint-*/
model-export/lora-adapters/**/dict.*.json
model-export/lora-adapters/**/model.SRC
model-export/lora-adapters/**/model.TGT
model-export/lora-adapters/**/tokenization_indictrans.py
model-export/lora-adapters/**/README.md
__pycache__/
*.pyc

# Bundled model binaries are produced by the Python pipeline
# (model-export/run_pipeline.sh). They are 70-200 MB each, exceed GitHub's
# 100 MB per-file limit, and are not tracked. To populate them locally:
#   cd model-export && ./run_pipeline.sh
app/assets/models/**/*.onnx
app/assets/models/**/*.onnx.data

# Bundled TTS voice packs are downloaded by bin/setup-dev-assets.sh.
# 60 MB (English) + 26 MB (Nepali), exceed GitHub's 100 MB limit.
# To populate locally: bash bin/setup-dev-assets.sh
app/assets/tts/**/*.onnx

# React Native / Expo
app/node_modules/
app/.expo/
app/dist/
app/web-build/
app/ios/
app/android/
app/*.jks
app/*.p12
app/*.key
app/*.mobileprovision

# Native build artifacts
app/ios/Pods/
app/ios/build/
app/android/build/
app/android/app/build/
app/android/.gradle/

# Metro
.metro-health-check*

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem
.env*

# IDE
.vscode/
.idea/
*.swp
