# Model export
model-export/bhasha-models/
model-export/models/
model-export/onnx/
model-export/onnx-quantized/
model-export/venv/
__pycache__/
*.pyc

# Bundled model binaries are produced by the Python pipeline
# (model-export/run_pipeline.sh). They are 70-200 MB each, exceed GitHub's
# 100 MB per-file limit, and are not tracked. To populate them locally:
#   cd model-export && ./run_pipeline.sh
app/assets/models/**/*.onnx
app/assets/models/**/*.onnx.data

# React Native / Expo
app/node_modules/
app/.expo/
app/dist/
app/web-build/
app/ios/
app/android/
app/*.jks
app/*.p12
app/*.key
app/*.mobileprovision

# Native build artifacts
app/ios/Pods/
app/ios/build/
app/android/build/
app/android/app/build/
app/android/.gradle/

# Metro
.metro-health-check*

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem
.env*

# IDE
.vscode/
.idea/
*.swp
