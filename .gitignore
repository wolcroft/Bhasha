# Model export
model-export/bhasha-models/
model-export/models/
model-export/onnx/
model-export/onnx-quantized/
model-export/venv/
__pycache__/
*.pyc

# NOTE: app/assets/models/*.onnx files are committed as ~0-byte placeholder
# stubs. After running model-export/copy_to_app.py they become ~280 MB each
# (~1 GB total). DO NOT git add them after the pipeline runs without first
# moving to Git LFS — they will exceed GitHub's 100 MB per-file limit.

